# ── API Server — copy this file to .env and fill in your values ──────────────

# PostgreSQL connection string
# If you started Postgres via Docker:
#   docker run -d --name pg -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/designer

# Port the API server listens on (frontend proxy points here)
PORT=8080
